    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "pg": "^8.20.0",
    "pino": "^9.3.2",
