# =====================================================================
# VoiceFlow — demo defaults
# All values point to local docker-compose services. No signup needed.
# Copy this file to `.env` and adjust if needed.
# =====================================================================

# --- backend ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# --- database (postgres container) ---
DATABASE_URL=postgresql://voiceflow:voiceflow@localhost:5433/voiceflow

# --- cache (redis container) ---
REDIS_URL=redis://localhost:6379

# --- object storage (minio container, S3-compatible) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=voiceflow-audio
S3_FORCE_PATH_STYLE=true

# --- email (mailhog container — catches all outbound mail at http://localhost:8025) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@voiceflow.local

# --- auth ---
JWT_SECRET=dev-only-change-me-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=10

# --- billing (disabled in v1) ---
BILLING_ENABLED=false
REVENUECAT_WEBHOOK_SECRET=

# --- telemetry (opt-in, disabled by default) ---
TELEMETRY_ENABLED=false

# --- mobile app -> backend ---
EXPO_PUBLIC_API_URL=http://localhost:4000
